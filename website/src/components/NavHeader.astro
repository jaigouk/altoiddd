---
/**
 * NavHeader — sticky top nav with logo, links, and CTA.
 * Left-aligned logo with monospace prompt character.
 */
---

<header class="nav-header">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="alty home">
      <span class="nav-logo-prompt">&gt;_</span>
      <span class="nav-logo-text">alty</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      <a href="/guides/quickstart/">Quick Start</a>
      <a href="/guides/concepts/">Concepts</a>
    </nav>

    <a href="/guides/quickstart/" class="nav-cta">
      Get Started
    </a>
  </div>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklch, var(--landing-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--landing-border);
  }

  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    text-decoration: none;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--landing-text);
  }

  .nav-logo-prompt {
    color: var(--landing-primary);
    font-size: 0.875rem;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    margin-left: auto;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--landing-text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 0;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--landing-text);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 1rem;
    min-height: 2.75rem;
    background: var(--landing-primary);
    color: var(--color-on-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    white-space: nowrap;
    transition: box-shadow 0.2s ease, opacity 0.15s ease, transform 0.15s ease;
  }

  .nav-cta:hover {
    opacity: 0.92;
    box-shadow: var(--glow-primary-sm);
  }

  .nav-cta:active {
    transform: translateY(1px);
    box-shadow: none;
    transition-duration: 0.05s;
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: 1rem;
    }

    .nav-cta {
      padding: 0.375rem 0.75rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 360px) {
    .nav-inner {
      gap: 1rem;
      padding: 0 1rem;
    }

    .nav-links {
      gap: 0.75rem;
    }

    .nav-links a {
      font-size: 0.8125rem;
    }
  }
</style>
