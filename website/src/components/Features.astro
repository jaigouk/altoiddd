---
/**
 * Features — 2×2 grid of feature cards with teal accent marks.
 * No icons — uses a left-border accent instead.
 */

const features = [
  {
    title: 'Guided Discovery',
    body: 'Interactive DDD discovery session extracts bounded contexts, aggregates, and domain events from your project description.',
  },
  {
    title: 'DDD Scaffolding',
    body: 'Generates domain model docs, bounded context maps, and layered architecture following DDD + SOLID + CQRS-lite patterns.',
  },
  {
    title: 'AI Tool Integration',
    body: 'Works as CLI or MCP server. Feeds structured context directly into Claude Code, Cursor, Roo Code, and OpenCode.',
  },
  {
    title: 'Architecture Fitness',
    body: 'Continuous validation ensures your project stays aligned with its architecture. Dependency rules, layer violations, and doc health — checked automatically.',
  },
];
---

<section class="features-section">
  <div class="features-inner">
    <p class="section-label">Features</p>
    <h2 class="section-title">
      Everything you need to<br class="hide-mobile" /> ship structured projects
    </h2>

    <div class="features-grid">
      {features.map((f) => (
        <div class="feature-card">
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-body">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 4rem 1.5rem 5rem;
  }

  .features-inner {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-label);
    color: var(--landing-primary);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--landing-text);
    margin-bottom: 3rem;
  }

  .hide-mobile {
    display: none;
  }

  @media (min-width: 768px) {
    .hide-mobile {
      display: inline;
    }
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    text-align: left;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .feature-card {
    padding: 1.5rem 1.5rem 1.5rem 1.75rem;
    background: var(--landing-surface);
    border: 1px solid var(--landing-border);
    border-left: 2px solid var(--landing-primary);
    border-radius: 0.5rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .feature-card:hover {
    border-color: var(--landing-primary);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card:hover {
      transform: none;
    }
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--landing-text);
    margin-bottom: 0.375rem;
  }

  .feature-body {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--landing-text-muted);
  }
</style>
