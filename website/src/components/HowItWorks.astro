---
/**
 * HowItWorks — three-step numbered section.
 * Describe → Discover → Build, left-aligned within each card.
 */

const steps = [
  {
    num: '01',
    title: 'Describe',
    body: 'Write 4–5 sentences about your project idea. What it does, who it\'s for, what problems it solves.',
  },
  {
    num: '02',
    title: 'Discover',
    body: 'alto asks targeted questions to map your project\'s boundaries, data structures, and key events — producing a proper domain model automatically.',
  },
  {
    num: '03',
    title: 'Build',
    body: 'Your AI coding tool gets PRD, DDD model, architecture docs, and structured tickets. It builds with guardrails, not guesses.',
  },
];
---

<section class="how-section">
  <div class="how-inner">
    <p class="section-label">How it works</p>
    <h2 class="section-title">
      From idea to structured project<br class="hide-mobile" /> in three steps
    </h2>

    <div class="steps-grid">
      {steps.map((step) => (
        <div class="step-card">
          <span class="step-num">{step.num}</span>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-section {
    padding: 4rem 1.5rem 5rem;
  }

  .how-inner {
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
  }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-label);
    color: var(--landing-primary);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--landing-text);
    margin-bottom: 3rem;
  }

  .hide-mobile {
    display: none;
  }

  @media (min-width: 768px) {
    .hide-mobile {
      display: inline;
    }
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .step-card {
    text-align: left;
    padding: 1.75rem;
    background: var(--landing-surface);
    border: 1px solid var(--landing-border);
    border-radius: 0.5rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .step-card:hover {
    border-color: var(--landing-primary);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .step-card:hover {
      transform: none;
    }
  }

  .step-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--landing-primary);
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--landing-text);
    margin-bottom: 0.5rem;
  }

  .step-body {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--landing-text-muted);
  }
</style>
