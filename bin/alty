#!/bin/bash
# =============================================================================
# alty — the AI architect for vibe coding
# =============================================================================
# Guided project setup enforcing DDD + TDD + SOLID with Beads issue tracking.
# Supports: Claude Code, Cursor, Roo Code, OpenCode
#
# Usage:
#   alty init                # New project in current directory
#   alty init --existing     # Apply to existing project (creates branch)
#   alty doc-health          # Check doc freshness and completeness
#   alty version             # Show alty version
#
# Safety rules:
#   - Preview all actions before executing
#   - Never overwrite existing files
#   - Conflict files get _alty suffix
#   - --existing always creates a new branch
#   - --existing runs existing tests after scaffolding (zero regression gate)
# =============================================================================

set -euo pipefail

VS_VERSION="0.1.0"
VS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Where alty keeps its seed files (templates, agents, knowledge)
SEED_DIR="$VS_DIR"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

# =============================================================================
# Action plan — collect actions, preview, then execute
# =============================================================================
declare -a PLAN_ACTIONS=()   # "CREATE|SKIP|RENAME|INSTALL|GLOBAL_OK|GLOBAL_WARN"
declare -a PLAN_DETAILS=()   # human-readable detail

plan_create() {
    PLAN_ACTIONS+=("CREATE")
    PLAN_DETAILS+=("$1")
}

plan_skip() {
    PLAN_ACTIONS+=("SKIP")
    PLAN_DETAILS+=("$1  ${DIM}(already exists)${NC}")
}

plan_rename() {
    PLAN_ACTIONS+=("RENAME")
    PLAN_DETAILS+=("$1  →  $2  ${DIM}(conflict)${NC}")
}

plan_install() {
    PLAN_ACTIONS+=("INSTALL")
    PLAN_DETAILS+=("$1  ${DIM}[optional]${NC}")
}

plan_global_ok() {
    PLAN_ACTIONS+=("GLOBAL_OK")
    PLAN_DETAILS+=("$1")
}

plan_global_warn() {
    PLAN_ACTIONS+=("GLOBAL_WARN")
    PLAN_DETAILS+=("$1")
}

show_plan() {
    echo
    echo -e "${BLUE}alty will set up the following:${NC}"
    echo

    local section=""
    for i in "${!PLAN_ACTIONS[@]}"; do
        local action="${PLAN_ACTIONS[$i]}"
        local detail="${PLAN_DETAILS[$i]}"

        case "$action" in
            CREATE)
                echo -e "  ${GREEN}CREATE${NC}   $detail" ;;
            SKIP)
                echo -e "  ${DIM}SKIP${NC}     $detail" ;;
            RENAME)
                echo -e "  ${YELLOW}RENAME${NC}   $detail" ;;
            INSTALL)
                echo -e "  ${BLUE}INSTALL${NC}  $detail" ;;
            GLOBAL_OK)
                echo -e "  ${GREEN}OK${NC}       $detail" ;;
            GLOBAL_WARN)
                echo -e "  ${YELLOW}⚠ WARN${NC}   $detail" ;;
        esac
    done
    echo
}

confirm() {
    local prompt="${1:-Proceed?}"
    echo -ne "${BOLD}$prompt${NC} [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]]
}

# =============================================================================
# File helpers — never overwrite, rename on conflict
# =============================================================================
safe_copy_file() {
    local src="$1"
    local dst="$2"

    if [ -f "$dst" ]; then
        # File exists — check if content differs
        if cmp -s "$src" "$dst" 2>/dev/null; then
            plan_skip "$dst"
        else
            # Conflict: rename our copy
            local dir ext base renamed
            dir="$(dirname "$dst")"
            base="$(basename "$dst")"
            ext="${base##*.}"
            if [ "$ext" = "$base" ]; then
                renamed="${dir}/${base}_alty"
            else
                renamed="${dir}/${base%.*}_alty.${ext}"
            fi
            plan_rename "$dst" "$renamed"
            RENAME_MAP["$src"]="$renamed"
        fi
    else
        plan_create "$dst"
        CREATE_MAP["$src"]="$dst"
    fi
}

safe_create_file() {
    local dst="$1"
    local content="$2"

    if [ -f "$dst" ]; then
        plan_skip "$dst"
    else
        plan_create "$dst"
        CREATE_CONTENT_MAP["$dst"]="$content"
    fi
}

safe_mkdir() {
    local dir="$1"
    if [ ! -d "$dir" ]; then
        plan_create "$dir/"
        MKDIR_LIST+=("$dir")
    fi
}

declare -A CREATE_MAP=()
declare -A RENAME_MAP=()
declare -A CREATE_CONTENT_MAP=()
declare -a MKDIR_LIST=()
declare -a INSTALL_TOOLS=()

execute_plan() {
    echo -e "${BLUE}Executing...${NC}"
    echo

    # Create directories
    for dir in "${MKDIR_LIST[@]}"; do
        mkdir -p "$dir"
    done

    # Copy files (CREATE)
    for src in "${!CREATE_MAP[@]}"; do
        local dst="${CREATE_MAP[$src]}"
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
        echo -e "  ${GREEN}✓${NC} $dst"
    done

    # Copy files (RENAME — conflict resolution)
    for src in "${!RENAME_MAP[@]}"; do
        local dst="${RENAME_MAP[$src]}"
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
        echo -e "  ${GREEN}✓${NC} $dst ${DIM}(renamed)${NC}"
    done

    # Create files from content
    for dst in "${!CREATE_CONTENT_MAP[@]}"; do
        mkdir -p "$(dirname "$dst")"
        echo "${CREATE_CONTENT_MAP[$dst]}" > "$dst"
        echo -e "  ${GREEN}✓${NC} $dst"
    done

    # Install tools
    for tool in "${INSTALL_TOOLS[@]}"; do
        install_tool "$tool"
    done
}

# =============================================================================
# Tool detection and installation
# =============================================================================
detect_tools() {
    echo -e "${BLUE}Detecting tools...${NC}"

    # Beads
    if command -v bd &> /dev/null; then
        local bd_ver
        bd_ver=$(bd --version 2>/dev/null | grep -oP '\d+\.\d+\.\d+' | head -1 || echo "unknown")
        echo -e "  Found: ${GREEN}Beads${NC} ($bd_ver)"
    else
        echo -e "  Missing: ${YELLOW}Beads${NC} (will install)"
        INSTALL_TOOLS+=("beads")
        plan_install "beads (bd) — git-native issue tracking"
    fi

    # Context7 (npx-based, just check npm/npx)
    if command -v npx &> /dev/null; then
        echo -e "  Found: ${GREEN}npx${NC} (for Context7 MCP)"
    else
        echo -e "  Missing: ${YELLOW}npx${NC} (needed for Context7 MCP — install Node.js)"
    fi

    # Trivy (optional)
    if command -v trivy &> /dev/null; then
        echo -e "  Found: ${GREEN}Trivy${NC}"
    else
        plan_install "trivy — vulnerability scanner"
    fi

    # uv
    if command -v uv &> /dev/null; then
        echo -e "  Found: ${GREEN}uv${NC}"
    else
        echo -e "  ${RED}Missing: uv (REQUIRED)${NC}"
        echo -e "  Install: curl -LsSf https://astral.sh/uv/install.sh | sh"
        exit 1
    fi

    echo
}

install_tool() {
    local tool="$1"
    case "$tool" in
        beads)
            echo -e "  Installing Beads..."
            if curl -fsSL https://raw.githubusercontent.com/steveyegge/beads/main/scripts/install.sh | bash; then
                [[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$HOME/.local/bin:$PATH"
                echo -e "  ${GREEN}✓${NC} Beads installed"
            else
                echo -e "  ${RED}✗${NC} Beads installation failed. Install manually."
            fi
            ;;
    esac
}

# =============================================================================
# Global settings detection
# =============================================================================
detect_global_settings() {
    echo -e "${BLUE}Global settings scan...${NC}"

    local found_conflicts=0

    # Claude Code
    if [ -d "$HOME/.claude" ]; then
        echo -e "  Found: Claude Code global config at ${DIM}~/.claude/${NC}"

        # Check CLAUDE.md
        if [ -f "$HOME/.claude/CLAUDE.md" ]; then
            # Check for git rules (compatible)
            if grep -q "Co-Authored-By" "$HOME/.claude/CLAUDE.md" 2>/dev/null; then
                plan_global_ok "~/.claude/CLAUDE.md: git rules compatible with alty"
            fi

            # Check for project-specific paths that won't apply
            if grep -qP 'src/(?!domain|application|infrastructure)' "$HOME/.claude/CLAUDE.md" 2>/dev/null; then
                plan_global_ok "~/.claude/CLAUDE.md: has project-specific paths (won't affect this project)"
            fi
        fi

        # Check settings.json for tool restrictions
        if [ -f "$HOME/.claude/settings.json" ] && command -v jq &> /dev/null; then
            local denied
            denied=$(jq -r '.permissions.deny // [] | join(", ")' "$HOME/.claude/settings.json" 2>/dev/null || echo "")
            if [ -n "$denied" ] && [ "$denied" != "" ]; then
                plan_global_warn "~/.claude/settings.json denies: $denied (agents may hit permission prompts)"
                found_conflicts=1
            fi
        fi
    fi

    # Cursor
    if [ -d "$HOME/.cursor" ]; then
        echo -e "  Found: Cursor global config at ${DIM}~/.cursor/${NC}"
    fi

    # Roo Code
    if [ -d "$HOME/.roo" ] || [ -d "$HOME/.agent" ]; then
        echo -e "  Found: Roo Code global config"
    fi

    if [ "$found_conflicts" -eq 0 ]; then
        echo -e "  ${GREEN}No conflicts detected${NC}"
    fi

    echo
}

# =============================================================================
# .gitignore management
# =============================================================================
ensure_gitignore_entry() {
    local entry="$1"
    local gitignore="$PROJECT_DIR/.gitignore"
    [ ! -f "$gitignore" ] && touch "$gitignore"
    grep -qxF "$entry" "$gitignore" 2>/dev/null || echo "$entry" >> "$gitignore"
}

fix_gitignore_entry() {
    local wrong="$1"
    local correct="$2"
    local gitignore="$PROJECT_DIR/.gitignore"
    if [ -f "$gitignore" ] && grep -qxF "$wrong" "$gitignore"; then
        sed -i "s|^$(printf '%s' "$wrong" | sed 's/[.[\*^$/]/\\&/g')$|${correct}|" "$gitignore"
        echo -e "  ${GREEN}✓${NC} Fixed .gitignore: '$wrong' → '$correct'"
    fi
}

setup_gitignore() {
    echo -e "  Updating .gitignore..."

    # Fix known wrong patterns
    fix_gitignore_entry ".cursor/" ".cursor/*"
    fix_gitignore_entry ".roo/" ".roo/*"

    # alty
    ensure_gitignore_entry ""
    ensure_gitignore_entry "# alty"
    ensure_gitignore_entry ".alty/cache/"

    # Python
    ensure_gitignore_entry ""
    ensure_gitignore_entry "# Python"
    ensure_gitignore_entry "__pycache__/"
    ensure_gitignore_entry "*.py[cod]"
    ensure_gitignore_entry "*.egg-info/"
    ensure_gitignore_entry "dist/"
    ensure_gitignore_entry "build/"
    ensure_gitignore_entry ".venv/"
    ensure_gitignore_entry ".coverage"
    ensure_gitignore_entry "htmlcov/"
    ensure_gitignore_entry ".pytest_cache/"
    ensure_gitignore_entry ".mypy_cache/"
    ensure_gitignore_entry ".ruff_cache/"

    # Claude Code
    ensure_gitignore_entry ""
    ensure_gitignore_entry "# Claude Code"
    ensure_gitignore_entry ".claude/*.local.md"
    ensure_gitignore_entry ".claude/*.local.json"

    # Cursor
    ensure_gitignore_entry ""
    ensure_gitignore_entry "# Cursor IDE"
    ensure_gitignore_entry ".cursor/*"
    ensure_gitignore_entry "!.cursor/rules/"
    ensure_gitignore_entry "!.cursor/mcp.json"

    # Roo Code
    ensure_gitignore_entry ""
    ensure_gitignore_entry "# Roo Code IDE"
    ensure_gitignore_entry ".roo/*"
    ensure_gitignore_entry "!.roo/rules-*"
    ensure_gitignore_entry "artifacts/"
    ensure_gitignore_entry ".agent/*"
    ensure_gitignore_entry "!.agent/rules/"
    ensure_gitignore_entry "!.agent/workflows/"

    # Environment
    ensure_gitignore_entry ""
    ensure_gitignore_entry "# Environment"
    ensure_gitignore_entry ".env"
    ensure_gitignore_entry ".env.local"

    echo -e "  ${GREEN}✓${NC} .gitignore updated"
}

# =============================================================================
# AGENTS.md
# =============================================================================
write_agents_md() {
    cat > "$PROJECT_DIR/AGENTS.md" << 'AGENTEOF'
# Agent Instructions

This project uses **bd** (beads) for issue tracking and follows **DDD + TDD + SOLID** principles.

## Quick Reference

```bash
bd ready              # Find available work
bd show <id>          # View issue details
bd update <id> --status in_progress  # Claim work
bd close <id>         # Complete work
bd export             # Export Dolt DB → JSONL (manual sync)
```

## Project Lifecycle

```
README → PRD → DDD → Architecture → Spikes → Implementation
```

Do NOT skip steps. No code before domain is understood.

## Quality Gates (Zero-Tolerance)

```bash
uv run ruff check .   # Lint — zero errors
uv run mypy .         # Types — zero errors
uv run pytest         # Tests — all pass
```

**If any fail, you are NOT DONE.**

## DDD Layer Rules

```
Domain           → ZERO external dependencies (pure Python)
Application      → Depends on Domain + Ports (interfaces only)
Infrastructure   → Implements Ports, depends on external libraries
```

## TDD Workflow

1. RED: Write failing test first
2. GREEN: Minimal code to pass
3. REFACTOR: Clean up, tests stay green

## SOLID Principles

- **S**ingle Responsibility: One class, one job
- **O**pen/Closed: Extend via composition, not modification
- **L**iskov Substitution: Subtypes honor base contracts
- **I**nterface Segregation: Focused protocols
- **D**ependency Inversion: Depend on abstractions

## Rules

- Do NOT commit or push without explicit user permission
- Do NOT proceed to next ticket without explicit user permission
AGENTEOF
}

# =============================================================================
# IDE setup — Claude Code
# =============================================================================
setup_claude_code() {
    if ! command -v claude &> /dev/null; then
        echo -e "  ${DIM}Claude Code CLI not found — skipping MCP setup${NC}"
        echo -e "  ${DIM}Install Claude Code, then run: alty init${NC}"
        return
    fi

    # Add context7 MCP server (user scope — shared across projects)
    if claude mcp get context7 &> /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} Claude MCP: context7 already configured"
    else
        claude mcp add --scope user context7 -- npx -y @upstash/context7-mcp
        echo -e "  ${GREEN}✓${NC} Claude MCP: added context7"
    fi
}

# =============================================================================
# IDE setup — Cursor
# =============================================================================
setup_cursor() {
    local mcp_file="$PROJECT_DIR/.cursor/mcp.json"

    mkdir -p "$PROJECT_DIR/.cursor/rules"

    if [ -f "$mcp_file" ]; then
        # Merge context7 if not present
        if command -v jq &> /dev/null; then
            if ! jq -e '.mcpServers.context7' "$mcp_file" &> /dev/null 2>&1; then
                local tmp
                tmp=$(mktemp)
                jq '.mcpServers["context7"] = {"command":"npx","args":["-y","@upstash/context7-mcp"]}' \
                    "$mcp_file" > "$tmp" && mv "$tmp" "$mcp_file"
                echo -e "  ${GREEN}✓${NC} Cursor: merged context7 into existing mcp.json"
            else
                echo -e "  ${GREEN}✓${NC} Cursor: context7 already in mcp.json"
            fi
        else
            echo -e "  ${YELLOW}⚠${NC} jq not found — add context7 manually to $mcp_file"
        fi
    else
        cat > "$mcp_file" << 'EOF'
{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
EOF
        echo -e "  ${GREEN}✓${NC} Cursor: created .cursor/mcp.json with context7"
    fi
}

# =============================================================================
# IDE setup — Roo Code
# =============================================================================
setup_roo_code() {
    mkdir -p "$PROJECT_DIR/.roo"
    mkdir -p "$PROJECT_DIR/.agent/rules"
    mkdir -p "$PROJECT_DIR/.agent/workflows"

    if [ ! -f "$PROJECT_DIR/.roo/rules-code.md" ]; then
        cat > "$PROJECT_DIR/.roo/rules-code.md" << AGEOF
# Project Rules for ${PROJECT_NAME}

This project follows DDD + TDD + SOLID principles.
See AGENTS.md for full instructions and quality gates.
AGEOF
        echo -e "  ${GREEN}✓${NC} Roo Code: created .roo/rules-code.md"
    else
        echo -e "  ${GREEN}✓${NC} Roo Code: rules-code.md already exists"
    fi

    echo -e "  ${DIM}ℹ Roo Code MCP: configure via IDE UI (Agent Panel → MCP Servers)${NC}"
}

# =============================================================================
# Seed files — copy templates, agents, knowledge
# =============================================================================
plan_seed_files() {
    # .alty directory
    safe_mkdir "$PROJECT_DIR/.alty"
    safe_mkdir "$PROJECT_DIR/.alty/knowledge"
    safe_mkdir "$PROJECT_DIR/.alty/maintenance"

    # Config
    safe_create_file "$PROJECT_DIR/.alty/config.toml" \
"# alty project configuration
[project]
name = \"$PROJECT_NAME\"
vs_version = \"$VS_VERSION\"
created = \"$(date -I)\"

[tools]
beads = true
context7 = true
trivy = false

[maintenance]
doc_review_interval_days = 30
"

    # Doc templates
    safe_mkdir "$PROJECT_DIR/docs/templates"
    for tmpl in PRD_TEMPLATE.md DDD_STORY_TEMPLATE.md ARCHITECTURE_TEMPLATE.md; do
        [ -f "$SEED_DIR/docs/templates/$tmpl" ] && \
            safe_copy_file "$SEED_DIR/docs/templates/$tmpl" "$PROJECT_DIR/docs/templates/$tmpl"
    done

    # Beads templates
    safe_mkdir "$PROJECT_DIR/docs/beads_templates"
    for tmpl in beads-epic-template.md beads-spike-template.md beads-ticket-template.md; do
        [ -f "$SEED_DIR/docs/beads_templates/$tmpl" ] && \
            safe_copy_file "$SEED_DIR/docs/beads_templates/$tmpl" "$PROJECT_DIR/docs/beads_templates/$tmpl"
    done

    # Spike reference
    safe_mkdir "$PROJECT_DIR/docs/spikes"
    [ -f "$SEED_DIR/docs/spikes/ddd_reference.md" ] && \
        safe_copy_file "$SEED_DIR/docs/spikes/ddd_reference.md" "$PROJECT_DIR/docs/spikes/ddd_reference.md"

    # Claude Code agents
    safe_mkdir "$PROJECT_DIR/.claude"
    safe_mkdir "$PROJECT_DIR/.claude/agents"
    safe_mkdir "$PROJECT_DIR/.claude/commands"
    for agent in developer.md researcher.md tech-lead.md project-manager.md qa-engineer.md white-hacker.md; do
        [ -f "$SEED_DIR/.claude/agents/$agent" ] && \
            safe_copy_file "$SEED_DIR/.claude/agents/$agent" "$PROJECT_DIR/.claude/agents/$agent"
    done
    for cmd in doc-health.md architecture-docs.md; do
        [ -f "$SEED_DIR/.claude/commands/$cmd" ] && \
            safe_copy_file "$SEED_DIR/.claude/commands/$cmd" "$PROJECT_DIR/.claude/commands/$cmd"
    done

    # CLAUDE.md
    [ -f "$SEED_DIR/.claude/CLAUDE.md" ] && \
        safe_copy_file "$SEED_DIR/.claude/CLAUDE.md" "$PROJECT_DIR/.claude/CLAUDE.md"

    # DDD source structure
    safe_mkdir "$PROJECT_DIR/src"
    safe_mkdir "$PROJECT_DIR/src/domain"
    safe_mkdir "$PROJECT_DIR/src/domain/models"
    safe_mkdir "$PROJECT_DIR/src/domain/services"
    safe_mkdir "$PROJECT_DIR/src/domain/events"
    safe_mkdir "$PROJECT_DIR/src/application"
    safe_mkdir "$PROJECT_DIR/src/application/commands"
    safe_mkdir "$PROJECT_DIR/src/application/queries"
    safe_mkdir "$PROJECT_DIR/src/application/ports"
    safe_mkdir "$PROJECT_DIR/src/infrastructure"
    safe_mkdir "$PROJECT_DIR/src/infrastructure/persistence"
    safe_mkdir "$PROJECT_DIR/src/infrastructure/messaging"
    safe_mkdir "$PROJECT_DIR/src/infrastructure/external"

    # Tests structure
    safe_mkdir "$PROJECT_DIR/tests"
    safe_mkdir "$PROJECT_DIR/tests/domain"
    safe_mkdir "$PROJECT_DIR/tests/application"
    safe_mkdir "$PROJECT_DIR/tests/infrastructure"
    safe_mkdir "$PROJECT_DIR/tests/integration"

    # __init__.py files for new directories
    for dir in src src/domain src/domain/models src/domain/services src/domain/events \
               src/application src/application/commands src/application/queries src/application/ports \
               src/infrastructure src/infrastructure/persistence src/infrastructure/messaging src/infrastructure/external \
               tests tests/domain tests/application tests/infrastructure tests/integration; do
        safe_create_file "$PROJECT_DIR/$dir/__init__.py" ""
    done

    # pyproject.toml
    [ -f "$SEED_DIR/pyproject.toml" ] && \
        safe_copy_file "$SEED_DIR/pyproject.toml" "$PROJECT_DIR/pyproject.toml"

    # .python-version
    safe_create_file "$PROJECT_DIR/.python-version" "3.12"

    # conftest.py
    [ -f "$SEED_DIR/tests/conftest.py" ] && \
        safe_copy_file "$SEED_DIR/tests/conftest.py" "$PROJECT_DIR/tests/conftest.py"
}

# =============================================================================
# Beads setup
# =============================================================================
setup_beads() {
    if ! command -v bd &> /dev/null; then
        echo -e "  ${YELLOW}Beads not available — skipping${NC}"
        return
    fi

    if [ ! -d "$PROJECT_DIR/.beads" ]; then
        bd init
        echo -e "  ${GREEN}✓${NC} Beads initialized"
    else
        echo -e "  ${GREEN}✓${NC} Beads already initialized"
    fi

    # Run doctor
    if ! bd doctor 2>&1 | tail -1 | grep -q '0 issue'; then
        echo "Y" | bd doctor --fix 2>&1 | tail -3
        bd export 2>/dev/null || true
    fi
}

# =============================================================================
# Existing project: branch + gap analysis + test verification
# =============================================================================
init_existing() {
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}  alty init --existing: ${PROJECT_NAME}${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo

    # Pre-flight: must be a git repo
    if [ ! -d "$PROJECT_DIR/.git" ]; then
        echo -e "${RED}Error: Not a git repository. Run 'git init' first or use 'alty init' for new projects.${NC}"
        exit 1
    fi

    # Pre-flight: clean working tree
    if [ -n "$(git -C "$PROJECT_DIR" status --porcelain)" ]; then
        echo -e "${RED}Error: Uncommitted changes detected.${NC}"
        echo -e "Commit or stash your changes first. alty init --existing requires a clean tree."
        exit 1
    fi

    # Pre-flight: branch doesn't exist
    local branch="alty/init"
    if git -C "$PROJECT_DIR" rev-parse --verify "$branch" &> /dev/null 2>&1; then
        echo -e "${RED}Error: Branch '$branch' already exists.${NC}"
        echo -e "Delete it first: git branch -D $branch"
        exit 1
    fi

    # Record current branch for rollback
    local original_branch
    original_branch=$(git -C "$PROJECT_DIR" rev-parse --abbrev-ref HEAD)

    # Detect existing test runner
    local test_cmd=""
    if [ -f "$PROJECT_DIR/pyproject.toml" ] && grep -q "pytest" "$PROJECT_DIR/pyproject.toml" 2>/dev/null; then
        test_cmd="uv run pytest"
    elif [ -f "$PROJECT_DIR/setup.cfg" ] || [ -f "$PROJECT_DIR/pytest.ini" ]; then
        test_cmd="python -m pytest"
    fi

    # Run existing tests BEFORE changes (baseline)
    local baseline_passed=true
    if [ -n "$test_cmd" ]; then
        echo -e "${BLUE}Running baseline tests...${NC}"
        if $test_cmd --tb=no -q 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} Baseline tests pass"
        else
            echo -e "  ${YELLOW}⚠${NC} Baseline tests already failing — will verify no NEW failures"
            baseline_passed=false
        fi
        echo
    fi

    # Detect tools and global settings
    detect_tools
    detect_global_settings

    # Plan seed files
    plan_seed_files

    # Show plan
    show_plan

    if ! confirm "Create branch '$branch' and apply these changes?"; then
        echo -e "${YELLOW}Aborted.${NC}"
        exit 0
    fi

    # Create branch
    echo
    git -C "$PROJECT_DIR" checkout -b "$branch"
    echo -e "  ${GREEN}✓${NC} Created branch: $branch"
    echo

    # Execute
    execute_plan
    setup_gitignore
    write_agents_md
    echo -e "  ${GREEN}✓${NC} AGENTS.md created"

    # IDE setup
    echo
    echo -e "${BLUE}IDE setup...${NC}"
    setup_claude_code
    setup_cursor
    setup_roo_code

    # Beads
    echo
    echo -e "${BLUE}Beads setup...${NC}"
    setup_beads

    # uv sync if pyproject.toml was created
    if [ -f "$PROJECT_DIR/pyproject.toml" ]; then
        echo
        echo -e "${BLUE}Installing dependencies...${NC}"
        uv sync --extra dev 2>&1 | tail -3
        echo -e "  ${GREEN}✓${NC} Dependencies installed"
    fi

    # TEST VERIFICATION — zero regression gate
    if [ -n "$test_cmd" ]; then
        echo
        echo -e "${BLUE}Running test verification (zero regression gate)...${NC}"
        if $test_cmd --tb=short -q 2>&1; then
            echo -e "  ${GREEN}✓${NC} All existing tests still pass"
        else
            echo -e "  ${RED}✗ TESTS FAILED — rolling back all changes${NC}"
            echo
            git -C "$PROJECT_DIR" checkout "$original_branch"
            git -C "$PROJECT_DIR" branch -D "$branch"
            echo -e "${RED}Branch '$branch' deleted. No changes applied.${NC}"
            echo -e "Fix the issue and try again."
            exit 1
        fi
    fi

    # Summary
    echo
    echo -e "${BLUE}========================================${NC}"
    echo -e "${GREEN}  Done! Changes are on branch: ${branch}${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo
    echo -e "Review the changes:"
    echo -e "  git diff ${original_branch}...${branch} --stat"
    echo -e "  git log ${original_branch}..${branch}"
    echo
    echo -e "When satisfied, merge:"
    echo -e "  git checkout ${original_branch}"
    echo -e "  git merge ${branch}"
    echo
    echo -e "Or discard:"
    echo -e "  git checkout ${original_branch}"
    echo -e "  git branch -D ${branch}"
}

# =============================================================================
# New project init
# =============================================================================
init_new() {
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}  alty init: ${PROJECT_NAME}${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo

    # Detect tools and global settings
    detect_tools
    detect_global_settings

    # Plan seed files
    plan_seed_files

    # Show plan
    show_plan

    if ! confirm; then
        echo -e "${YELLOW}Aborted.${NC}"
        exit 0
    fi

    echo

    # Execute
    execute_plan
    setup_gitignore
    write_agents_md
    echo -e "  ${GREEN}✓${NC} AGENTS.md created"

    # IDE setup
    echo
    echo -e "${BLUE}IDE setup...${NC}"
    setup_claude_code
    setup_cursor
    setup_roo_code

    # Git init if needed
    if [ ! -d "$PROJECT_DIR/.git" ]; then
        git init "$PROJECT_DIR" > /dev/null
        echo -e "  ${GREEN}✓${NC} Git initialized"
    fi

    # Beads
    echo
    echo -e "${BLUE}Beads setup...${NC}"
    setup_beads

    # uv sync
    if [ -f "$PROJECT_DIR/pyproject.toml" ]; then
        echo
        echo -e "${BLUE}Installing dependencies...${NC}"
        uv sync --extra dev 2>&1 | tail -3
        echo -e "  ${GREEN}✓${NC} Dependencies installed"
    fi

    # Summary
    echo
    echo -e "${BLUE}========================================${NC}"
    echo -e "${GREEN}  Setup Complete: ${PROJECT_NAME}${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo
    echo -e "Tools:"
    command -v bd &> /dev/null && echo -e "  ${GREEN}✓${NC} Beads (bd)" || echo -e "  ${RED}✗${NC} Beads"
    command -v npx &> /dev/null && echo -e "  ${GREEN}✓${NC} Context7 (npx)" || echo -e "  ${RED}✗${NC} Context7"
    echo
    echo -e "IDE configs:"
    [ -d "$PROJECT_DIR/.claude" ] && echo -e "  ${GREEN}✓${NC} Claude Code"
    [ -f "$PROJECT_DIR/.cursor/mcp.json" ] && echo -e "  ${GREEN}✓${NC} Cursor"
    [ -d "$PROJECT_DIR/.roo" ] && echo -e "  ${GREEN}✓${NC} Roo Code"
    echo
    echo -e "${YELLOW}Next steps:${NC}"
    echo "  1. Edit README.md with your project idea (4-5 sentences)"
    echo "  2. Copy docs/templates/PRD_TEMPLATE.md → docs/PRD.md"
    echo "  3. Copy docs/templates/DDD_STORY_TEMPLATE.md → docs/DDD.md"
    echo "  4. Run 'bd ready' to see available tasks"
    echo
    echo -e "${DIM}Project lifecycle: README → PRD → DDD → Architecture → Spikes → Implementation${NC}"
}

# =============================================================================
# Doc health check
# =============================================================================
cmd_doc_health() {
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}  Doc Health Report: ${PROJECT_NAME}${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo

    local issues=0
    local checked=0

    # Key docs to check
    local -a docs=("docs/PRD.md" "docs/DDD.md" "docs/ARCHITECTURE.md")

    for doc in "${docs[@]}"; do
        local filepath="$PROJECT_DIR/$doc"
        checked=$((checked + 1))

        if [ ! -f "$filepath" ]; then
            echo -e "  ${RED}MISSING${NC}  $doc"
            issues=$((issues + 1))
            continue
        fi

        # Check for last_reviewed in frontmatter
        local reviewed
        reviewed=$(grep -oP 'last_reviewed:\s*\K\S+' "$filepath" 2>/dev/null | head -1)

        if [ -z "$reviewed" ] || [ "$reviewed" = "YYYY-MM-DD" ]; then
            echo -e "  ${YELLOW}⚠ STALE${NC}   $doc  ${DIM}(no last_reviewed date)${NC}"
            issues=$((issues + 1))
        else
            # Calculate days since review
            local reviewed_epoch today_epoch days_ago
            reviewed_epoch=$(date -d "$reviewed" +%s 2>/dev/null || echo 0)
            today_epoch=$(date +%s)
            days_ago=$(( (today_epoch - reviewed_epoch) / 86400 ))

            if [ "$days_ago" -gt 30 ]; then
                echo -e "  ${YELLOW}⚠ STALE${NC}   $doc  ${DIM}(${days_ago}d since review, threshold: 30)${NC}"
                issues=$((issues + 1))
            else
                echo -e "  ${GREEN}OK${NC}       $doc  ${DIM}(${days_ago}d ago)${NC}"
            fi
        fi
    done

    # Check all docs in docs/ for frontmatter
    while IFS= read -r -d '' mdfile; do
        local rel="${mdfile#$PROJECT_DIR/}"
        # Skip templates and already-checked
        [[ "$rel" == docs/templates/* ]] && continue
        [[ "$rel" == docs/beads_templates/* ]] && continue
        [[ "$rel" == docs/reference/* ]] && continue

        local already_checked=false
        for doc in "${docs[@]}"; do
            [ "$rel" = "$doc" ] && already_checked=true
        done
        $already_checked && continue

        checked=$((checked + 1))
        if ! grep -q 'last_reviewed:' "$mdfile" 2>/dev/null; then
            echo -e "  ${DIM}INFO${NC}     $rel  ${DIM}(no frontmatter)${NC}"
        fi
    done < <(find "$PROJECT_DIR/docs" -name "*.md" -print0 2>/dev/null)

    echo
    echo -e "${BLUE}========================================${NC}"
    if [ "$issues" -eq 0 ]; then
        echo -e "${GREEN}  ✓ All $checked docs healthy${NC}"
    else
        echo -e "${YELLOW}  ⚠ $issues issue(s) found across $checked docs${NC}"
    fi
    echo -e "${BLUE}========================================${NC}"
}

# =============================================================================
# Main — command dispatch
# =============================================================================
case "${1:-help}" in
    init)
        if [[ "${2:-}" == "--existing" ]]; then
            init_existing
        else
            init_new
        fi
        ;;
    doc-health)
        cmd_doc_health
        ;;
    version)
        echo "alty $VS_VERSION"
        ;;
    help|--help|-h)
        echo "alty — the AI architect for vibe coding"
        echo
        echo "Usage:"
        echo "  alty init              New project setup (preview → confirm → scaffold)"
        echo "  alty init --existing   Apply to existing project (branch → scaffold → test)"
        echo "  alty doc-health        Check documentation freshness and completeness"
        echo "  alty version           Show version"
        echo "  alty help              Show this help"
        echo
        echo "Safety:"
        echo "  - All actions previewed before execution"
        echo "  - Existing files never overwritten"
        echo "  - --existing creates a branch, never modifies current branch"
        echo "  - --existing verifies zero test regressions"
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'alty help' for usage."
        exit 1
        ;;
esac
